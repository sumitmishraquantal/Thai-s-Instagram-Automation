# ── LLM ───────────────────────────────────────────────────
LLM_PROVIDER=groq
GROQ_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
GROQ_MODEL=llama-3.3-70b-versatile

# ── Topic research (YouTube Data API v3 + Serper) ─────────
YOUTUBE_API_KEY=
SERPER_API_KEY=
YOUTUBE_REGION_CODE=US
YOUTUBE_RELEVANCE_LANGUAGE=en
SERPER_GL=us
SERPER_HL=en
RESEARCH_LOOKBACK_DAYS=30

# ── Approval (pause before video generation) ──────────────
REQUIRE_APPROVAL=true
OWNER_EMAILS=owner@example.com
APPROVAL_BASE_URL=http://localhost:8000
EMAIL_TRANSPORT=auto
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
COMPOSIO_API_KEY=
GMAIL_SENDER=
COMPOSIO_USER_ID=
COMPOSIO_TOOLKIT_VERSION=

# ── ElevenLabs TTS ────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_v3
HOST_VOICE_ID=CwhRBWXzGAHq8TQ4Fs17
GUEST_VOICE_ID=RDjgzX0qNSGQZkgo5KTT

# Blank = LLM picks category automatically
DEFAULT_CATEGORY=

# ── Video provider ────────────────────────────────────────
# hf_mcp = Seedance 2.0 via MCP OAuth | hf_platform = REST API
VIDEO_PROVIDER=hf_platform
HF_API_KEY=
HF_API_SECRET=
HF_MCP_URL=https://mcp.higgsfield.ai/mcp
HF_MCP_CALLBACK_PORT=3030
HF_MAX_CREDITS_PER_CLIP=60
HF_IMAGE_MODEL=higgsfield-ai/soul/standard
HF_IMAGE_REF_MODEL=higgsfield-ai/soul/reference
HF_VIDEO_MODEL=bytedance/seedance/v1/lite/image-to-video
HF_VIDEO_RESOLUTION=720
HF_IMAGE_RESOLUTION=1080p
HF_ASPECT_RATIO=9:16

# fal.ai (optional alternative)
FAL_KEY=
FAL_VIDEO_MODEL=bytedance/seedance-2.0/reference-to-video
FAL_IMAGE_EDIT_MODEL=fal-ai/bytedance/seedream/v4/edit
FAL_IMAGE_MODEL=fal-ai/bytedance/seedream/v4/text-to-image
FAL_VIDEO_RESOLUTION=720p

# ── Pipeline tuning ───────────────────────────────────────
SCENE_LIMIT=0
CHAIN_SCENES=true
REACTION_SHOTS_ENABLED=true
REACTION_MIN_SECONDS=7.0
USE_DIRECTOR_SKILLS=true
SEEDANCE_BILINGUAL_PROMPT=false
ESTABLISHING_TWO_SHOT=true

# ── GDrive upload — raw Higgsfield scene clips only (scene_01.mp4 → RawClip1.mp4, …) ──
UPLOAD_TO_GDRIVE=true
RCLONE_REMOTE=gdrive:reel-projects/TEST
RCLONE_EXE=rclone
RCLONE_CONFIG=
GDRIVE_CLIP_PREFIX=RawClip
GDRIVE_SUBFOLDER_PER_REEL=false
GDRIVE_DELETE_LOCAL_AFTER_UPLOAD=false

# ── Scheduler (optional cron automation) ────────────────
SCHEDULE_ENABLED=false
SCHEDULE_CRON=0 9 * * *
SCHEDULE_WORKFLOW=podcast
SCHEDULE_TOPIC=
